# Copy snippets into variables.auto.tfvars (or merge with your existing file).
# Repository .gitignore ignores *.auto.tfvars — keep local-only values there.
#
# Certificates: upload each PFX to Key Vault as a secret (Base64 PKCS#12), then reference secret_name.
#   az keyvault secret set --vault-name <vault> --name appgw-ssl --file cert.pfx
# Terraform (and CI) must be able to read those secrets during plan/apply.
# Application Gateway uses a user-assigned managed identity with Key Vault secret Get on that vault.

# --- Disabled (default-style) -------------------------------------------------
# app_gateway_config = {
#   enabled = false
#   sites   = []
# }

# --- Example: single hostname + one KV secret ---------------------------------
# app_gateway_config = {
#   enabled                 = true
#   sku_name                = "WAF_v2"
#   sku_tier                = "WAF_v2"
#   capacity                = 2
#   subnet_address_prefixes = ["10.36.4.0/26"]
#   redirect_http_to_https  = true
#   # key_vault_id = null  # omit to use module Key Vault kv-cc-infocomp-<environment>
#   ssl_certificates = {
#     main = { secret_name = "appgw-ssl-app-example-com" }
#   }
#   sites = [
#     {
#       name                = "primary"
#       host_name           = "app.example.com"
#       ssl_certificate_key = "main"
#     }
#   ]
# }

# --- Example: multiple domains (one secret per cert) --------------------------
# app_gateway_config = {
#   enabled   = true
#   sku_name  = "WAF_v2"
#   sku_tier  = "WAF_v2"
#   capacity  = 2
#   ssl_certificates = {
#     app_a = { secret_name = "appgw-ssl-a-example-com" }
#     app_b = { secret_name = "appgw-ssl-b-example-com" }
#   }
#   sites = [
#     { name = "site-a", host_name = "a.example.com", ssl_certificate_key = "app_a" },
#     { name = "site-b", host_name = "b.example.com", ssl_certificate_key = "app_b" },
#   ]
# }

# --- Example: Standard_v2 (no inline WAF) -------------------------------------
# app_gateway_config = {
#   enabled                  = true
#   sku_name                 = "Standard_v2"
#   sku_tier                 = "Standard_v2"
#   enable_waf_configuration = false
#   firewall_policy_id       = null
#   ssl_certificates         = { main = { secret_name = "appgw-ssl-main" } }
#   sites = [
#     { name = "primary", host_name = "www.example.com", ssl_certificate_key = "main" }
#   ]
# }
